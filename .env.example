# datahaus environment configuration
# Copy to .env and adjust as needed

# Airflow
AIRFLOW_HOME=~/datahaus/.airflow
AIRFLOW__CORE__DAGS_FOLDER=~/datahaus/pipelines
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Java (PySpark requires Java 17)
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# DuckDB warehouse path (relative to project root)
DATAHAUS_WAREHOUSE=warehouse/datahaus.duckdb
